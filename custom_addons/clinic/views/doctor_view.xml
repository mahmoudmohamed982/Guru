<odoo>

    <!-- ============================= -->
    <!-- Doctor Form View -->
    <!-- ============================= -->
    <record id="clinic_doctor_form" model="ir.ui.view">
        <field name="name">clinic.doctor.form</field>
        <field name="model">clinic.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="specialization"/>

                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================= -->
    <!-- Doctor Tree View -->
    <!-- ============================= -->
    <record id="clinic_doctor_tree" model="ir.ui.view">
        <field name="name">clinic.doctor.tree</field>
        <field name="model">clinic.doctor</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="specialization"/>
                <field name="patient_ids"/>
            </tree>
        </field>
    </record>

    <!-- ============================= -->
    <!-- Doctor Action -->
    <!-- ============================= -->
    <record id="action_clinic_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">clinic.doctor</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ============================= -->
    <!-- Doctor Menu -->
    <!-- ============================= -->
    <menuitem
        id="doctor_item"
        name="Doctors"
        parent="doctor_menu"
        action="action_clinic_doctor"
    />

</odoo>
