<odoo>
    <record id="view_factory_production_line_form" model="ir.ui.view">
        <field name="name">factory.production.line.form</field>
        <field name="model">factory.production.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="code" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Machines">
                            <field name="machine_ids"/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>
    <record id="view_factory_production_line_tree" model="ir.ui.view">
        <field name="name">factory.production.line.tree</field>
        <field name="model">factory.production.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="active"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_factory_production_line_search" model="ir.ui.view">
        <field name="name">factory.production.line.search</field>
        <field name="model">factory.production.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>
    
    <record id="action_factory_production_line" model="ir.actions.act_window">
        <field name="name">Production Lines</field>
        <field name="res_model">factory.production.line</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
        id="production_lines_menu"
        name="Production Lines"
        parent="factory_config_menu"
        action="action_factory_production_line"
    />

</odoo>