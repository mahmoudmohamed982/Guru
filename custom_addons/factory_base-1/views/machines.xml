<odoo>
    <record id="view_factory_machine_form" model="ir.ui.view">
        <field name="name">factory.machine.form</field>
        <field name="model">factory.machine</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="code" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Production Lines">
                            <field name="production_line_id"/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_factory_machine_tree" model="ir.ui.view">
        <field name="name">factory.machine.tree</field>
        <field name="model">factory.machine</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="active"/>
                <field name="code"/>
                <field name="production_line_id"/>
                <field name="serial_number"/>
                <field name="manufacturer"/>
            </tree>
        </field>
    </record>

    <record id="view_factory_machine_search" model="ir.ui.view">
        <field name="name">factory.machine.search</field>
        <field name="model">factory.machine</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="serial_number"/>
            </search>
        </field>
    </record>

    <record id="action_factory_machines" model="ir.actions.act_window">
        <field name="name">Machines</field>
        <field name="res_model">factory.machine</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="machines_menu"
        name="Machines"
        parent="factory_config_menu"
        action="action_factory_machines"
    />

</odoo>